# ─── Local (localhost) ───────────────────────────────────────────────────────
# Métadonnées médias → PostgreSQL ; fichiers → dossier /media (pas de Supabase).
# Ne pas définir les variables S3_* en local.

DATABASE_URI=postgresql://cinemergence:cinemergence@localhost:5433/cinemergence
PAYLOAD_SECRET=change-me-min-32-characters-long
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optionnel : forcer le mode (auto = local en dev, supabase en prod)
# MEDIA_STORAGE=local

# ─── Production (Vercel uniquement) ──────────────────────────────────────────
# Supabase Storage → Dashboard → Storage → S3 Connection → Access keys
# Bucket public requis : cinemergence-media

# S3_BUCKET=cinemergence-media
# S3_REGION=eu-central-1
# S3_ENDPOINT=https://PROJECT_REF.storage.supabase.co/storage/v1/s3
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# SUPABASE_STORAGE_PUBLIC_URL=https://PROJECT_REF.supabase.co/storage/v1/object/public/cinemergence-media
# MIGRATE_MEDIA_SECRET=random-secret-for-seed-migrate-storage

# ─── Authentification (Clerk) ────────────────────────────────────────────────
# Dashboard → clerk.com → créer une application → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ─── Intégrations ────────────────────────────────────────────────────────────

# Brevo (newsletter + notifications formulaire contact)
# xsmtpsib-… = clé SMTP (relai smtp-relay.brevo.com) | xkeysib-… = clé API REST v3
BREVO_API_KEY=
BREVO_LIST_ID=
# Login SMTP Brevo — obligatoire si BREVO_API_KEY commence par xsmtpsib-
# Brevo → SMTP & API → onglet SMTP → « Login SMTP » (format xxx@smtp-brevo.com)
BREVO_SMTP_LOGIN=
# Expéditeur vérifié dans Brevo (souvent la même adresse que le destinataire au début)
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Cinémergence

# Google Analytics (loaded after cookie consent)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Contact form notifications (destinataire des formulaires contact/inscription/financement)
CONTACT_NOTIFICATION_EMAIL=verdat.sylvain@gmail.com
