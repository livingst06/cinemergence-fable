# ─── Local (localhost) ───────────────────────────────────────────────────────
# Métadonnées médias → PostgreSQL ; fichiers → dossier /media (pas de Supabase).
# Ne pas définir les variables S3_* en local.

DATABASE_URI=postgresql://cinemergence:cinemergence@localhost:5433/cinemergence
PAYLOAD_SECRET=change-me-min-32-characters-long
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optionnel : forcer le mode (auto = local en dev, supabase en prod)
# MEDIA_STORAGE=local

# ─── Production (Vercel uniquement) ──────────────────────────────────────────
# Supabase Storage → Dashboard → Storage → S3 Connection → Access keys
# Bucket public requis : cinemergence-media

# S3_BUCKET=cinemergence-media
# S3_REGION=eu-central-1
# S3_ENDPOINT=https://PROJECT_REF.storage.supabase.co/storage/v1/s3
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# SUPABASE_STORAGE_PUBLIC_URL=https://PROJECT_REF.supabase.co/storage/v1/object/public/cinemergence-media
# MIGRATE_MEDIA_SECRET=random-secret-for-seed-migrate-storage

# ─── Intégrations ────────────────────────────────────────────────────────────

# Brevo (newsletter)
BREVO_API_KEY=
BREVO_LIST_ID=

# Google Analytics (loaded after cookie consent)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Contact form notifications
CONTACT_NOTIFICATION_EMAIL=cinemergence.paris@gmail.com
