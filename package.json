{
  "name": "cinemergence-fable",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "curl -s -X POST http://localhost:3000/api/seed",
    "seed:media": "curl -s -X POST 'http://localhost:3000/api/seed/media?force=1'",
    "seed:hero": "curl -s -X POST http://localhost:3000/api/seed/hero",
    "migrate:storage": "curl -s -X POST 'http://localhost:3000/api/seed/migrate-storage?force=1'",
    "migrate:prod": "NODE_OPTIONS='--require ./scripts/next-env-shim.cjs' tsx scripts/migrate-media-prod.ts",
    "migrate:intervenants": "NODE_OPTIONS='--require ./scripts/next-env-shim.cjs' tsx scripts/update-intervenants-prod.ts",
    "seed:intervenants": "NODE_OPTIONS='--require ./scripts/next-env-shim.cjs' tsx scripts/update-intervenants-local.ts",
    "seed:founder": "curl -s -X POST http://localhost:3000/api/seed/founder",
    "migrate:founder": "NODE_OPTIONS='--require ./scripts/next-env-shim.cjs' tsx scripts/update-founder-prod.ts",
    "supabase:rls": "NODE_OPTIONS='--require ./scripts/next-env-shim.cjs' tsx scripts/apply-supabase-rls.ts",
    "sync:site-url": "NODE_OPTIONS='--require ./scripts/next-env-shim.cjs' tsx scripts/update-site-url-prod.ts",
    "sync:media": "tsx src/seed/sync-public-media.ts",
    "generate:importmap": "payload generate:importmap",
    "generate:types": "payload generate:types",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@next/env": "^16.2.10",
    "@payloadcms/db-postgres": "^3.85.2",
    "@payloadcms/next": "^3.85.2",
    "@payloadcms/richtext-lexical": "^3.85.2",
    "@payloadcms/storage-s3": "^3.85.2",
    "@radix-ui/react-accordion": "^1.2.15",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "graphql": "^16.14.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "payload": "^3.85.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.12.0",
    "sharp": "^0.35.3",
    "sonner": "1.7.4",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.22.5",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
